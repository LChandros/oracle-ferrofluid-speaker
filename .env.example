# Oracle Speaker Environment Variables
# Copy this file to .env and fill in your actual values

# OpenAI API Key (required for Claude fallback in voice assistant)
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Moneo API Configuration
# MONEO_API_URL=http://100.71.119.36:3002/api/voice/chat
# MONEO_API_KEY=your_moneo_api_key_here

# Optional: Direct Claude API fallback
# CLAUDE_API_KEY=your_claude_api_key_here
